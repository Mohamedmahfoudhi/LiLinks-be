# PointPay QR Card Generation Module
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pointpay
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# QR Code Security
# IMPORTANT: Generate a strong random secret for production
# Example: openssl rand -hex 32
QR_SECRET=your_super_secret_hmac_key_change_this_in_production

# JWT Configuration
# IMPORTANT: Generate strong random secrets for production
# Example: openssl rand -hex 64
JWT_ACCESS_SECRET=your_jwt_access_token_secret_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_change_this_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Security Configuration
BCRYPT_ROUNDS=12

# OTP Configuration
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Rate Limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
